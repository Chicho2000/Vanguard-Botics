// Chumi - Cochera Automática
// Schema de base de datos para sistema de estacionamiento inteligente

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// 0. Enums Globales
// ──────────────────────────────────────────────
enum Role {
  ADMIN
  CLIENTE
  INVITADO
}

// ──────────────────────────────────────────────
// 1. Usuarios registrados (los que crean cuenta)
// ──────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(CLIENTE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles      Vehicle[]
  subscriptions Subscription[]

  @@map("users")
}

// ──────────────────────────────────────────────
// 2. Vehículos (registrados o no)
//    userId null = auto sin cuenta, solo patente
// ──────────────────────────────────────────────
model Vehicle {
  id           Int      @id @default(autoincrement())
  licensePlate String   @unique
  userId       Int?
  brand        String?
  model        String?
  color        String?
  heightCm     Float?
  widthCm      Float?
  weightKg     Float?
  createdAt    DateTime @default(now())

  user     User?            @relation(fields: [userId], references: [id])
  sessions ParkingSession[]

  @@index([licensePlate])
  @@map("vehicles")
}

// ──────────────────────────────────────────────
// 3. Pisos de la cochera
// ──────────────────────────────────────────────
model Floor {
  id          Int    @id @default(autoincrement())
  name        String // "Planta Baja", "Piso 1"
  level       Int    // 0, 1, 2...
  maxHeightCm Float
  maxWeightKg Float
  maxWidthCm  Float

  spots ParkingSpot[]

  @@map("floors")
}

// ──────────────────────────────────────────────
// 4. Espacios individuales de estacionamiento
// ──────────────────────────────────────────────
enum SpotType {
  NORMAL
  DISABLED
  EV_CHARGING
  MOTORCYCLE
}

model ParkingSpot {
  id         Int      @id @default(autoincrement())
  label      String   // "A1", "B3"
  floorId    Int
  row        Int      // para el mapa visual (grid)
  column     Int      // para el mapa visual (grid)
  isOccupied Boolean  @default(false)
  spotType   SpotType @default(NORMAL)
  maxWidthCm Float    // ancho físico del espacio

  floor    Floor            @relation(fields: [floorId], references: [id])
  sessions ParkingSession[]

  @@unique([floorId, row, column])
  @@map("parking_spots")
}

// ──────────────────────────────────────────────
// 5. Sesiones de estacionamiento (entrada/salida)
// ──────────────────────────────────────────────
enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model ParkingSession {
  id                   Int           @id @default(autoincrement())
  vehicleId            Int
  spotId               Int
  entryAt              DateTime      @default(now())
  exitAt               DateTime?
  totalMinutes         Int?
  amountCharged        Float?
  status               SessionStatus @default(ACTIVE)
  paidWithSubscription Boolean       @default(false)

  vehicle Vehicle     @relation(fields: [vehicleId], references: [id])
  spot    ParkingSpot @relation(fields: [spotId], references: [id])
  payment Payment?

  @@map("parking_sessions")
}

// ──────────────────────────────────────────────
// 6. Abonos (solo usuarios registrados)
// ──────────────────────────────────────────────
enum SubscriptionType {
  HOURS
  DAILY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model Subscription {
  id             Int                @id @default(autoincrement())
  userId         Int
  type           SubscriptionType
  hoursRemaining Int? // solo para tipo HOURS
  validFrom      DateTime           @default(now())
  validUntil     DateTime
  status         SubscriptionStatus @default(ACTIVE)
  createdAt      DateTime           @default(now())

  user    User     @relation(fields: [userId], references: [id])
  payment Payment?

  @@map("subscriptions")
}

// ──────────────────────────────────────────────
// 7. Pagos
// ──────────────────────────────────────────────
enum PaymentMethod {
  MERCADO_PAGO
  CASH
  TRANSFER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Payment {
  id                Int           @id @default(autoincrement())
  sessionId         Int?          @unique
  subscriptionId    Int?          @unique
  amount            Float
  method            PaymentMethod @default(MERCADO_PAGO)
  externalPaymentId String? // ID de Mercado Pago
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime      @default(now())

  session      ParkingSession? @relation(fields: [sessionId], references: [id])
  subscription Subscription?   @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}
